<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Away Game Gas Calculator | VegasInsider</title>
    <style>
        :root {
            --vi-gold: #ffcc00;
            --vi-black: #1a1a1a;
            --vi-dark-grey: #2d2d2d;
            --vi-white: #ffffff;
            --vi-green: #00c853;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #0d0d0d;
            color: var(--vi-white);
            display: flex;
            justify-content: center;
            padding: 20px;
        }

        .calculator-card {
            background-color: var(--vi-black);
            border: 1px solid var(--vi-dark-grey);
            border-radius: 12px;
            width: 100%;
            max-width: 550px;
            padding: 30px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.6);
        }

        .header {
            text-align: center;
            border-bottom: 2px solid var(--vi-gold);
            margin-bottom: 25px;
            padding-bottom: 15px;
        }

        .header h1 {
            margin: 0;
            font-size: 26px;
            text-transform: uppercase;
            font-style: italic;
            letter-spacing: 1px;
        }

        .header h1 span { color: var(--vi-gold); }

        .input-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
        }

        .input-group { margin-bottom: 15px; }

        label {
            display: block;
            margin-bottom: 5px;
            font-size: 11px;
            color: #999;
            text-transform: uppercase;
            font-weight: bold;
        }

        input, select {
            width: 100%;
            padding: 12px;
            background-color: var(--vi-dark-grey);
            border: 1px solid #444;
            color: white;
            border-radius: 4px;
            font-size: 15px;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            font-size: 13px;
            color: var(--vi-gold);
            cursor: pointer;
        }

        .checkbox-group input {
            width: auto;
            margin-right: 10px;
        }

        input:focus { border-color: var(--vi-gold); outline: none; }

        .btn-calculate {
            width: 100%;
            padding: 18px;
            background-color: var(--vi-gold);
            color: black;
            border: none;
            border-radius: 4px;
            font-weight: 900;
            font-size: 18px;
            cursor: pointer;
            text-transform: uppercase;
            margin-top: 10px;
        }

        .results {
            margin-top: 25px;
            display: none;
            background: #252525;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid var(--vi-gold);
        }

        .main-stat {
            font-size: 32px;
            color: var(--vi-gold);
            font-weight: bold;
            text-align: center;
            margin: 10px 0;
        }

        .stat-label { text-align: center; font-size: 12px; color: #aaa; margin-bottom: 5px;}

        .summary-box {
            display: flex;
            justify-content: space-around;
            border-top: 1px solid #444;
            padding-top: 15px;
        }

        .summary-item { text-align: center; }
        .summary-item div:first-child { font-size: 10px; color: #888; text-transform: uppercase; }
        .summary-item div:last-child { font-size: 18px; font-weight: bold; color: var(--vi-green); }
        
        .disclaimer {
            font-size: 11px;
            color: #777;
            text-align: center;
            margin-top: 15px;
            line-height: 1.3;
        }
    </style>
</head>
<body>

<div class="calculator-card">
    <div class="header">
        <h1><span>VEGAS</span>INSIDER</h1>
        <p style="margin:5px 0 0; font-size: 14px; color: #888;">Fan Travel Expense Tracker</p>
    </div>

    <div class="input-row">
        <div class="input-group">
            <label>Current State</label>
            <select id="stateSelect" onchange="populateCities()">
                <option value="">Select State</option>
            </select>
        </div>
        <div class="input-group">
            <label>Home City</label>
            <select id="citySelect">
                <option value="">Select City</option>
            </select>
        </div>
    </div>

    <div class="checkbox-group">
        <input type="checkbox" id="localFan" onchange="toggleLocal()">
        <label for="localFan" style="margin:0; color:var(--vi-gold); cursor:pointer;">I live in the stadium city (Local Fan)</label>
    </div>

    <div class="input-row">
        <div class="input-group" id="milesContainer">
            <label>Round Trip Miles</label>
            <input type="number" id="miles" placeholder="e.g. 300">
        </div>
        <div class="input-group">
            <label>Vehicle MPG</label>
            <input type="number" id="mpg" value="22">
        </div>
    </div>

    <div class="input-group">
        <label>Number of Fans in Car</label>
        <input type="number" id="fans" value="1">
    </div>

    <button class="btn-calculate" onclick="calculate()">Find My Lowest Cost</button>

    <div id="results" class="results">
        <div class="stat-label">CHEAPEST POSSIBLE TRIP COST</div>
        <div class="main-stat" id="totalCost">$0.00</div>
        
        <div class="summary-box">
            <div class="summary-item">
                <div>Per Fan</div>
                <div id="perFan">$0.00</div>
            </div>
            <div class="summary-item">
                <div>Best Price</div>
                <div id="appliedPrice">$0.00</div>
            </div>
        </div>
        
        <p id="insight" style="font-size: 13px; color: #bbb; text-align: center; margin-top: 20px; line-height: 1.4; border-top: 1px solid #444; padding-top: 15px;"></p>
        
        <div class="disclaimer">
            *Calculation Caveat: This is the absolute minimum you'll pay for gas if you use the <strong>cheapest</strong> identified gas station in your city based on current market data.
        </div>
    </div>
</div>

