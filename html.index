    ];

    // State dropdown setup
    const stateSet = [...new Set(gasData.map(item => item.s))].sort();
    const stateEl = document.getElementById('stateSelect');
    stateSet.forEach(s => {
        let opt = document.createElement('option');
        opt.value = s;
        opt.innerText = s;
        stateEl.appendChild(opt);
    });

    function populateCities() {
        const state = stateEl.value;
        const cityEl = document.getElementById('citySelect');
        cityEl.innerHTML = '<option value="">Select Home City</option>';
        
        const cities = gasData.filter(item => item.s === state).sort((a,b) => a.c.localeCompare(b.c));
        cities.forEach(item => {
            let opt = document.createElement('option');
            opt.value = item.p;
            opt.dataset.station = item.st;
            opt.innerText = item.c.charAt(0).toUpperCase() + item.c.slice(1).replace(/-/g, ' ');
            cityEl.appendChild(opt);
        });
    }

    function toggleLocal() {
        const isLocal = document.getElementById('localFan').checked;
        const milesInput = document.getElementById('miles');
        if (isLocal) {
            milesInput.value = 30; // Standard urban round trip
            milesInput.disabled = true;
        } else {
            milesInput.value = "";
            milesInput.disabled = false;
        }
    }

    function calculate() {
        const gasPrice = parseFloat(document.getElementById('citySelect').value);
        const miles = parseFloat(document.getElementById('miles').value);
        const mpg = parseFloat(document.getElementById('mpg').value);
        const fans = parseFloat(document.getElementById('fans').value);
        const isLocal = document.getElementById('localFan').checked;

        if (!gasPrice || !miles || !mpg || fans < 1) {
            alert("Please complete all fields.");
            return;
        }

        const totalCost = (miles / mpg) * gasPrice;
        const costPerFan = totalCost / fans;
        
        document.getElementById('totalCost').innerText = '$' + totalCost.toFixed(2);
        document.getElementById('perFan').innerText = '$' + costPerFan.toFixed(2);
        document.getElementById('appliedPrice').innerText = '$' + gasPrice.toFixed(2);
        
        const mode = isLocal ? "Commute" : "Road Trip";
        document.getElementById('insight').innerHTML = `<strong>VEGAS INSIDER SCOUTING REPORT:</strong> This ${mode} is a lock. Split with ${fans} fans, you're paying less than a stadium soda to get to the game!`;
        
        document.getElementById('results').style.display = 'block';
    }
</script>

</body>
</html>
